<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust Booking Receipt - <%= booking._id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: #333;
        }
        .invoice-card {
            border: 1px solid #dee2e6;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        .invoice-header {
            background-color: #f8f9fa;
            border-top-left-radius: 11px;
            border-top-right-radius: 11px;
        }
        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background-color: #fff;
            }
            .invoice-card {
                border: none;
                box-shadow: none;
            }
        }
    </style>
</head>
<body class="bg-light py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-9 col-lg-8">
                <!-- Action Controls (Hidden when printing) -->
                <div class="d-flex justify-content-between align-items-center mb-4 no-print">
                    <a href="/profile?tab=payments" class="btn btn-outline-dark rounded-pill">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
                    </a>
                    <button onclick="window.print();" class="btn btn-danger rounded-pill px-4">
                        <i class="fa-solid fa-print me-2"></i>Print / Save PDF
                    </button>
                </div>

                <!-- Invoice Content -->
                <div class="card invoice-card border-0 bg-white">
                    <div class="invoice-header p-4 border-bottom d-flex justify-content-between align-items-center flex-wrap">
                        <div>
                            <h2 class="fw-bold text-danger mb-0"><i class="fa-solid fa-compass me-2"></i>Wanderlust</h2>
                            <p class="text-secondary small mb-0 mt-1">Official Payment Receipt & Invoice</p>
                        </div>
                        <div class="text-md-end mt-2 mt-md-0">
                            <span class="badge bg-success-subtle text-success border border-success-subtle py-2 px-3 fs-6 rounded-pill">
                                <i class="fa-solid fa-circle-check me-1"></i><%= payment ? payment.status.toUpperCase() : "PAID" %>
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <!-- Invoice Info -->
                        <div class="row mb-4">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <span class="text-secondary small d-block">ISSUED TO:</span>
                                <strong><%= booking.guest.username %></strong>
                                <div class="text-secondary small"><%= booking.guest.email %></div>
                            </div>
                            <div class="col-sm-6 text-sm-end">
                                <span class="text-secondary small d-block">INVOICE DETAILS:</span>
                                <div><strong>Invoice ID:</strong> <%= payment ? payment._id : 'N/A' %></div>
                                <div><strong>Booking ID:</strong> <%= booking._id %></div>
                                <div><strong>Payment Date:</strong> <%= new Date(booking.paymentTimestamp || (payment ? payment.timestamp : Date.now())).toLocaleDateString("en-US", {month: 'long', day: 'numeric', year: 'numeric'}) %></div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- Stay Details -->
                        <h5 class="fw-bold mb-3">Reservation Details</h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="p-3 border rounded bg-light h-100">
                                    <div class="text-secondary small mb-1">PROPERTY:</div>
                                    <h6 class="fw-bold mb-1"><%= booking.listing.title %></h6>
                                    <div class="text-secondary small"><i class="fa-solid fa-location-dot me-1"></i><%= booking.listing.location %>, <%= booking.listing.country %></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded bg-light h-100">
                                    <div class="text-secondary small mb-1">STAY DURATION:</div>
                                    <h6 class="fw-bold mb-1"><%= new Date(booking.checkInDate).toLocaleDateString() %> - <%= new Date(booking.checkOutDate).toLocaleDateString() %></h6>
                                    <div class="text-secondary small">
                                        <i class="fa-solid fa-moon me-1 text-danger"></i><%= nights %> Nights &middot; 
                                        <i class="fa-solid fa-users me-1 text-danger"></i><%= booking.guestCount %> Guests
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Price Breakdown -->
                        <h5 class="fw-bold mb-3">Charges Breakdown</h5>
                        <table class="table table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end" style="width: 150px;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        Accommodation Base Rate
                                        <div class="text-secondary small">₹<%= booking.listing.price.toLocaleString("en-IN") %> per night x <%= nights %> nights</div>
                                    </td>
                                    <td class="text-end">₹<%= pricing.basePrice.toLocaleString("en-IN", {minimumFractionDigits: 2}) %></td>
                                </tr>
                                <tr>
                                    <td>
                                        Platform Service Charge (5%)
                                        <div class="text-secondary small">Charged for secure rental processing</div>
                                    </td>
                                    <td class="text-end">₹<%= pricing.platformFee.toLocaleString("en-IN", {minimumFractionDigits: 2}) %></td>
                                </tr>
                                <tr>
                                    <td>
                                        GST (18% on Accommodation Base Price)
                                        <div class="text-secondary small">Government sales & services tax</div>
                                    </td>
                                    <td class="text-end">₹<%= pricing.gst.toLocaleString("en-IN", {minimumFractionDigits: 2}) %></td>
                                </tr>
                                <tr class="table-light fs-5">
                                    <td class="fw-bold">Total Paid</td>
                                    <td class="text-end fw-bold text-danger">₹<%= pricing.total.toLocaleString("en-IN", {minimumFractionDigits: 2}) %></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Transaction Metadata -->
                        <div class="p-3 border rounded-3 bg-light mt-4">
                            <h6 class="fw-bold mb-2"><i class="fa-solid fa-shield-halved text-success me-2"></i>Transaction Parameters</h6>
                            <div class="row g-2 small text-secondary">
                                <div class="col-sm-6">
                                    <strong>Gateway Provider:</strong> Razorpay Test
                                </div>
                                <div class="col-sm-6">
                                    <strong>Razorpay Order ID:</strong> <%= booking.razorpayOrderId %>
                                </div>
                                <div class="col-sm-6">
                                    <strong>Razorpay Payment ID:</strong> <%= booking.razorpayPaymentId || 'N/A' %>
                                </div>
                                <div class="col-sm-6">
                                    <strong>Razorpay Signature:</strong> <span class="text-truncate d-inline-block" style="max-width: 200px;"><%= booking.razorpaySignature || 'N/A' %></span>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-5 text-secondary small">
                            <p>Thank you for choosing Wanderlust! We hope you have an incredible stay.</p>
                            <p class="mb-0">This receipt has been generated automatically and serves as proof of booking and payment confirmation.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
